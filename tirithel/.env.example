# Tirithel - AI Support UI Learning Tool
# Copy this file to .env and fill in your values

# Database (SQLite for MVP)
DB_URL=sqlite+aiosqlite:///./data/tirithel.db

# LLM (Claude API)
LLM_ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=4096

# OCR
OCR_ENGINE=tesseract
OCR_LANGUAGE=eng
OCR_CONFIDENCE_THRESHOLD=0.6

# Embeddings & Vector Search
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_CHROMA_PERSIST_DIR=./data/chromadb

# Storage
STORAGE_SCREENSHOT_DIR=./data/screenshots

# Application
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_ALLOWED_ORIGINS=*
APP_SCREENSHOT_INTERVAL_SECONDS=3
