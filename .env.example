# Application
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_API_PREFIX=/api/v1
APP_JWT_SECRET=change-me-in-production

# Database
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gov_pay
DB_ECHO=false
DB_POOL_SIZE=20

# Stripe Gateway
GATEWAY_DEFAULT_PROVIDER=stripe
GATEWAY_STRIPE_SECRET_KEY=sk_test_...
GATEWAY_STRIPE_PUBLISHABLE_KEY=pk_test_...
GATEWAY_STRIPE_WEBHOOK_SECRET=whsec_...

# Authorize.Net Gateway
GATEWAY_AUTHNET_API_LOGIN_ID=
GATEWAY_AUTHNET_TRANSACTION_KEY=
GATEWAY_AUTHNET_SANDBOX=true

# Tyler Tech ERM
ERM_TYLER_TECH_API_URL=https://api.tylertech.example.com
ERM_TYLER_TECH_API_KEY=
ERM_TYLER_TECH_API_SECRET=
ERM_TYLER_TECH_TIMEOUT=30
